# Exemple de configuration (ne jamais committer .env réel).
#
# Copiez ce fichier en .env.local et remplissez les valeurs.

APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
HSTS_ENABLED=false

DEFAULT_URI=http://127.0.0.1:8000

# Exemple SQLite (dev)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"

# Exemple MySQL
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
MAILER_DSN=null://null

ALERTJET_NOTIFY_EMAIL=
ALERTJET_MAIL_FROM="AlertJet <alertjet@localhost>"

MAIL_WEBHOOK_URL=
MAIL_WEBHOOK_SECRET=

APP_ADMIN_BOOTSTRAP_PASSWORD=

INVITE_WEBHOOK_URL=

